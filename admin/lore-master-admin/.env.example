# Google OAuth Web client ID (same value as backend GOOGLE_CLIENT_ID audience).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com

# Backend API only — must be your Express/functions service URL (e.g. lore-master-production…),
# NOT the admin Next.js URL (do not use dependable-bravery / admin domain here).
NEXT_PUBLIC_API_URL=https://your-backend-service.up.railway.app
