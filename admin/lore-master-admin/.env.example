# Public Google OAuth Web client ID (same project as backend GOOGLE_CLIENT_ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Backend API base URL (Railway service URL for the functions API — no trailing slash).
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app

# Optional alias; if set, should match NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_ADMIN_API_URL=https://your-api.up.railway.app
