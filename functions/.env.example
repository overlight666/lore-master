# PostgreSQL (Railway plugin provides this). On deploy, `npm start` runs `prisma migrate deploy` then the API.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Google Sign-In — Web client ID(s); comma-separated if multiple (e.g. web + Android client IDs)
GOOGLE_CLIENT_ID=299075414532-e30v4eobguhltvhqe9t24c5crq0dke1l.apps.googleusercontent.com

# Optional: bootstrap roles on first /auth/init-user (comma-separated emails, lowercase matching)
# SUPER_ADMIN_EMAILS=you@company.com
# ADMIN_EMAILS=other@company.com

# CORS: your admin frontend origin(s), comma-separated
CORS_ORIGINS=https://dependable-bravery-production.up.railway.app

# Server
PORT=8080
NODE_ENV=production
